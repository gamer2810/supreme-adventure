---
layout: none
permalink: /blog-data.json
---

{%- comment -%}Pre-compute global word totals and flag counts{%- endcomment -%}
{%- assign total_words = 0 -%}
{%- assign posts_with_math = 0 -%}
{%- assign posts_with_mermaid = 0 -%}
{%- for post in site.posts -%}
  {%- assign _w = post.content | number_of_words -%}
  {%- assign total_words = total_words | plus: _w -%}
  {%- if post.math == true -%}{%- assign posts_with_math = posts_with_math | plus: 1 -%}{%- endif -%}
  {%- if post.mermaid -%}{%- assign posts_with_mermaid = posts_with_mermaid | plus: 1 -%}{%- endif -%}
{%- endfor -%}
{%- assign _n = site.posts.size -%}
{%- assign avg_words = total_words | divided_by: _n -%}
{%- assign avg_rt = total_words | times: 1.0 | divided_by: 180 | divided_by: _n | ceil -%}
{%- assign math_pct = posts_with_math | times: 100.0 | divided_by: _n | round: 1 -%}
{%- assign mermaid_pct = posts_with_mermaid | times: 100.0 | divided_by: _n | round: 1 -%}
{
  "meta": {
    "generated_at": "{{ 'now' | date: '%Y-%m-%dT%H:%M:%SZ' }}",
    "total_posts": {{ _n }},
    "date_range": {
      "first": "{{ site.posts.last.date | date: '%Y-%m-%d' }}",
      "last": "{{ site.posts.first.date | date: '%Y-%m-%d' }}"
    }
  },
  "posts": [
    {%- for post in site.posts -%}
    {%- assign _words = post.content | number_of_words -%}
    {%- assign _rt = _words | times: 1.0 | divided_by: 180 | ceil -%}
    {%- if _rt < 1 -%}{%- assign _rt = 1 -%}{%- endif -%}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | prepend: site.url | jsonify }},
      "date": "{{ post.date | date: '%Y-%m-%d' }}",
      "date_unix": {{ post.date | date: '%s' }},
      "year": {{ post.date | date: '%Y' | plus: 0 }},
      "month": "{{ post.date | date: '%Y-%m' }}",
      "month_num": {{ post.date | date: '%m' | plus: 0 }},
      "categories": {{ post.categories | jsonify }},
      "tags": {{ post.tags | jsonify }},
      "description": {{ post.description | default: "" | jsonify }},
      "word_count": {{ _words }},
      "reading_time_min": {{ _rt }},
      "has_math": {% if post.math == true %}true{% else %}false{% endif %},
      "has_toc": {% if post.toc == false %}false{% else %}true{% endif %},
      "has_mermaid": {% if post.mermaid %}true{% else %}false{% endif %},
      "has_image": {% if post.image and post.image != false %}true{% else %}false{% endif %},
      "last_modified_at": "{{ post.last_modified_at | default: post.date | date: '%Y-%m-%d' }}"
    }{% unless forloop.last %},{% endunless %}
    {%- endfor %}
  ],
  "aggregated": {
    "summary": {
      "total_posts": {{ _n }},
      "total_words": {{ total_words }},
      "avg_words_per_post": {{ avg_words }},
      "avg_reading_time_min": {{ avg_rt }},
      "posts_with_math_pct": {{ math_pct }},
      "posts_with_mermaid_pct": {{ mermaid_pct }}
    },
    "by_month": [
      {%- assign posts_by_month = site.posts | group_by_exp: "post", "post.date | date: '%Y-%m'" | sort: "name" -%}
      {%- for mg in posts_by_month -%}
      {%- assign _mw = 0 -%}
      {%- assign _mm = 0 -%}
      {%- assign _md = 0 -%}
      {%- assign _mi = 0 -%}
      {%- for post in mg.items -%}
        {%- assign _pw = post.content | number_of_words -%}
        {%- assign _mw = _mw | plus: _pw -%}
        {%- if post.math == true -%}{%- assign _mm = _mm | plus: 1 -%}{%- endif -%}
        {%- if post.mermaid -%}{%- assign _md = _md | plus: 1 -%}{%- endif -%}
        {%- if post.image and post.image != false -%}{%- assign _mi = _mi | plus: 1 -%}{%- endif -%}
      {%- endfor -%}
      {
        "month": {{ mg.name | jsonify }},
        "post_count": {{ mg.items.size }},
        "total_words": {{ _mw }},
        "avg_words": {{ _mw | divided_by: mg.items.size }},
        "posts_with_math": {{ _mm }},
        "posts_with_mermaid": {{ _md }},
        "posts_with_image": {{ _mi }}
      }{% unless forloop.last %},{% endunless %}
      {%- endfor %}
    ],
    "categories": [
      {%- for cat in site.categories -%}
      {
        "name": {{ cat[0] | jsonify }},
        "count": {{ cat[1].size }},
        "pct": {{ cat[1].size | times: 100.0 | divided_by: _n | round: 1 }}
      }{% unless forloop.last %},{% endunless %}
      {%- endfor %}
    ],
    "tags": [
      {%- for tag in site.tags -%}
      {
        "name": {{ tag[0] | jsonify }},
        "count": {{ tag[1].size }},
        "pct": {{ tag[1].size | times: 100.0 | divided_by: _n | round: 1 }}
      }{% unless forloop.last %},{% endunless %}
      {%- endfor %}
    ]
  }
}
